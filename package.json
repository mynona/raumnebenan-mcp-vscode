{
  "name": "raumnebenan-mcp-vscode",
  "displayName": "raumnebenan - product thinking",
  "description": "raumnebenan.de is a resource hub focused on actionable product thinking for product owners, product designers, business analysts, product managers, agile coaches, and user researchers. The site provides clear, structured guides and tools to help teams understand users, identify opportunities, validate ideas, and deliver products that create real user and business value.",
  "version": "0.2.9",
  "license": "MIT",
  "publisher": "raumnebenan",
  "icon": "images/raumnebenan.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mynona/raumnebenan-mcp-vscode.git"
  },

  "engines": {
    "vscode": "^1.95.0"
  },

  "extensionKind": ["workspace"],

  "categories": ["AI", "Chat"],

  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "language-model-tools",
    "product thinking"
  ],

  "enabledApiProposals": [
    "mcpServerDefinitions",
    "mcpToolDefinitions"
  ],

  "activationEvents": [
    "onLanguageModelTools",
    "onLanguageModelChat"
  ],

  "main": "./out/extension.js",

  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "raumnebenan.mcp-server",
        "label": "raumnebenan"
      }
    ]
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },

  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
