{
  "name": "raumnebenan-mcp-vscode",
  "displayName": "raumnebenan-mcp",
  "description": "raumnebenan.de is a resource hub focused on actionable product thinking for product owners, product designers, business analysts, product managers, agile coaches, and user researchers. The site provides clear, structured guides and tools to help teams understand users, identify opportunities, validate ideas, and deliver products that create real user and business value.",
  "version": "0.1.6",
  "license": "MIT",
  "publisher": "raumnebenan",
  "icon": "images/raumnebenan.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mynona/raumnebenan-mcp-vscode.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "product thinking",
    "product vision",
    "product strategy",
    "product roadmap",
    "usability",
    "design thinking",
    "design sprint",
    "user research",
    "prioritization",
    "agile development",
    "co-creation workshop"
  ],
  "enabledApiProposals": [
    "mcpServerDefinitions"
  ],
  "activationEvents": [
    "onLanguageModelMcpServerDefinitionProvider:raumnebenan-mcp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "raumnebenan-mcp",
        "label": "raumnebenan-mcp"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
